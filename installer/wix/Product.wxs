<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="DocuCapture"
    Manufacturer="DocuCapture"
    Version="1.0.0"
    UpgradeCode="A2E9D40A-5A82-41DE-A7F7-39F3C98ACD11">
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DocuCapture" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDocuCapture" Name="DocuCapture" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="DocuCapture" Level="1">
      <ComponentGroupRef Id="GeneratedGroup" />
      <ComponentRef Id="cmp_startmenu_shortcut" />
    </Feature>
  </Package>

  <Fragment>
    <DirectoryRef Id="ProgramMenuDocuCapture">
      <Component Id="cmp_startmenu_shortcut" Guid="E3B2C4D5-6A7B-8C9D-0E1F-2A3B4C5D6E7F">
        <Shortcut
          Id="ShortcutDocuCapture"
          Name="DocuCapture"
          Target="[INSTALLFOLDER]Installed-Launch.cmd"
          WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\DocuCapture" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
